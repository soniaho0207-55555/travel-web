{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "travel-h5",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path');const mime={'html':'text/html','css':'text/css','js':'application/javascript','json':'application/json','png':'image/png','jpg':'image/jpeg','svg':'image/svg+xml'};http.createServer((q,r)=>{let f=path.join(process.cwd(),q.url==='/'?'/index-h5.html':q.url);fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');return}const ext=path.extname(f).slice(1);r.writeHead(200,{'Content-Type':mime[ext]||'application/octet-stream'});r.end(d)})}).listen(8090,()=>console.log('ok'))"],
      "port": 8090
    }
  ]
}
